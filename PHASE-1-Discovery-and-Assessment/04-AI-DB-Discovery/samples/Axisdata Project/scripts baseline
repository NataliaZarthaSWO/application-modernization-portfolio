#!/usr/bin/env python

import csv
import re
import sys

# Check if a keyword, a CSV file, and an output file were provided as command-line arguments
if len(sys.argv) < 4:
    print("Usage: search.py keyword file.csv output.csv")
    sys.exit(1)

# Get the keyword, the CSV file, and the output file from the command-line arguments
keyword = sys.argv[1]
csv_file = sys.argv[2]
output_file = sys.argv[3]

# Define the regular expression pattern to match the keyword
pattern = re.compile(rf"\b{keyword}\b")

# Open the CSV file
with open(csv_file, "r") as f:
    # Read the CSV file as a dictionary
    reader = csv.DictReader(f)

    # Open the output file
    with open(output_file, "w") as f:
        # Create a writer object to write the output to the file
        writer = csv.writer(f)

        # Iterate over the rows in the CSV file
        for row in reader:
            # Get the file name from the row
            filename = row["file"]

            # Open the file
            with open(filename, "r") as f:
                # Read the file content
                content = f.read()

                # Search for the matches in the content
                for match in pattern.finditer(content):
                    # Get the matched text
                    text = content[match.start():match.end()]

                    # Write the file name, the line number, and the matched text to the output file
                    writer.writerow([filename, match.start(), text])

